# Required
MONGO_URI=mongodb://localhost:27017
MONGO_DB=development
WHATSAPP_WEBHOOK_BASE="your-whatsapp-webhook-base"
AI_TEST_ADMIN_ID=

# Optional override: if empty, admin_id is used as userid
AI_TEST_USER_ID=

# Optional: fixed user identity for all chats
AI_TEST_USER_NAME=
AI_TEST_PHONE_NUMBER=

# Optional: agent mode default max turns
AI_TEST_AGENT_MAX_TURNS=5

# Optional: if empty, auto-resolve from whatsappchannels by admin_id
AI_TEST_PHONE_NUMBER_ID=
AI_TEST_DISPLAY_PHONE_NUMBER=

# Tuning
AI_TEST_POLL_TIMEOUT_SECONDS=45
AI_TEST_POLL_INTERVAL_MS=1500

# Optional analytics
AI_TEST_ENABLE_ANALYTICS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
